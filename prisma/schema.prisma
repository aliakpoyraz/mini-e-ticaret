// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  price       Decimal
  imageUrl    String?
  category    String?
  variants    Variant[]
  discounts   Discount[]
  favorites   Favorite[]
  images      ProductImage[]
  reviews     Review[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Variant {
  id        Int       @id @default(autoincrement())
  name      String    // e.g., "Small/Red"
  sku       String    @unique
  stock     Int       @default(0)
  productId Int
  product   Product   @relation(fields: [productId], references: [id])
  orderItems OrderItem[]
}

model Order {
  id              Int         @id @default(autoincrement())
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  status          String      @default("CREATED") // CREATED, PAID, SHIPPED, DELIVERED, RETURNED
  total           Decimal
  items           OrderItem[]
  userId          Int?
  user            User?       @relation(fields: [userId], references: [id])
  customerName    String
  customerAddress String
  customerEmail   String
  customerPhone   String    @default("")
  paymentMethod   String    @default("CREDIT_CARD")
  couponCode      String?
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  order     Order   @relation(fields: [orderId], references: [id])
  variantId Int
  variant   Variant @relation(fields: [variantId], references: [id])
  quantity  Int
  price     Decimal // Snapshot price at time of order
}

model StoreSettings {
  id          Int      @id @default(1)
  storeName   String   @default("My Store")
  description String?
  email       String?
  phone       String?
  address     String?
  currency    String   @default("USD")
  updatedAt   DateTime @updatedAt
}

model Discount {
  id           Int       @id @default(autoincrement())
  name         String
  type         String    // PERCENTAGE or FIXED
  value        Decimal
  active       Boolean   @default(true)
  productId    Int?      // If null, it's a cart-level discount
  product      Product?  @relation(fields: [productId], references: [id])
  minCartValue Decimal?  // Only applicable if productId is null
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Coupon {
  id           Int       @id @default(autoincrement())
  code         String    @unique
  type         String    // PERCENTAGE or FIXED
  value        Decimal
  minCartValue Decimal?
  active       Boolean   @default(true)
  usageLimit   Int?      // Null means unlimited
  usedCount    Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model User {
  id        Int        @id @default(autoincrement())
  email     String     @unique
  password  String     
  firstName String?
  lastName  String?
  phone     String?
  role      String     @default("USER") // USER or ADMIN
  isBanned  Boolean    @default(false)
  isVerified      Boolean    @default(false)
  verificationToken String?
  resetToken        String?
  resetTokenExpiry  DateTime?
  favorites Favorite[]
  orders    Order[]
  addresses Address[]
  reviews   Review[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Address {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  title     String   // e.g., "Ev", "İş"
  address   String
  city      String
  country   String   @default("Türkiye")
  zipCode   String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Favorite {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  productId Int
  product   Product  @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model ProductImage {
  id        Int      @id @default(autoincrement())
  url       String
  productId Int
  product   Product  @relation(fields: [productId], references: [id])
  order     Int      @default(0) // For sorting
  createdAt DateTime @default(now())
}

model Review {
  id        Int      @id @default(autoincrement())
  rating    Int      // 1-5
  comment   String?
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  productId Int
  product   Product  @relation(fields: [productId], references: [id])
  status    String   @default("APPROVED") // APPROVED, PENDING, REJECTED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
}
